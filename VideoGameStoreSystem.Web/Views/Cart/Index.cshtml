@model VideoGameStoreSystem.Web.ViewModels.Cart.CartIndexViewModel

@{
    ViewData["Title"] = "Корзина";
}

<div class="page-card mb-4">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
        <div>
            <h2 class="fw-bold mb-1">Корзина</h2>
            <p class="text-muted mb-0">Подбор товаров перед оформлением покупки в магазине видеоигр.</p>
        </div>
        <a asp-controller="Catalog" asp-action="Index" class="btn btn-outline-primary">
            <i class="bi bi-arrow-left me-1"></i>Вернуться в каталог
        </a>
    </div>
</div>

@if (Model.Items.Count == 0)
{
    <div class="page-card text-center py-5">
        <div class="display-6 mb-3 text-muted"><i class="bi bi-cart-x"></i></div>
        <h4 class="fw-semibold">Корзина пока пуста</h4>
        <p class="text-muted mb-4">Добавьте товары из каталога, чтобы сформировать список интересующих позиций.</p>
        <a asp-controller="Catalog" asp-action="Index" class="btn btn-primary">Перейти в каталог</a>
    </div>
}
else
{
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="page-card">
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                            <tr>
                                <th>Товар</th>
                                <th>Цена</th>
                                <th>Количество</th>
                                <th>Сумма</th>
                                <th class="text-end">Действия</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Items)
                            {
                                <tr>
                                    <td>
                                        <div class="fw-semibold">@item.ProductName</div>
                                        <div class="small text-muted">@item.CategoryName · @item.Sku</div>
                                        @if (!item.IsActive)
                                        {
                                            <div class="small text-danger mt-1">Товар снят с продажи.</div>
                                        }
                                        else if (item.StockQuantity < item.Quantity)
                                        {
                                            <div class="small text-warning mt-1">Доступно на складе: @item.StockQuantity шт.</div>
                                        }
                                    </td>
                                    <td>@item.Price.ToString("N2") ₽</td>
                                    <td>
                                        <form asp-action="Update" method="post" class="d-flex gap-2 align-items-center cart-update-form">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="productId" value="@item.ProductId" />
                                            <input type="number"
                                                   name="quantity"
                                                   value="@item.Quantity"
                                                   min="1"
                                                   max="@(Math.Max(item.StockQuantity, 1))"
                                                   class="form-control form-control-sm cart-qty-input" />
                                            <button type="submit" class="btn btn-outline-primary btn-sm">Обновить</button>
                                        </form>
                                    </td>
                                    <td class="fw-semibold">@item.LineTotal.ToString("N2") ₽</td>
                                    <td class="text-end">
                                        <div class="d-flex justify-content-end gap-2">
                                            <a asp-controller="Catalog" asp-action="Details" asp-route-id="@item.ProductId" class="btn btn-outline-secondary btn-sm">Карточка</a>
                                            <form asp-action="Remove" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="productId" value="@item.ProductId" />
                                                <button type="submit" class="btn btn-outline-danger btn-sm">Удалить</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="page-card">
                <h5 class="fw-semibold mb-3">Сводка по корзине</h5>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted">Количество товаров</span>
                    <span class="fw-semibold">@Model.TotalQuantity</span>
                </div>
                <div class="d-flex justify-content-between mb-3">
                    <span class="text-muted">Общая сумма</span>
                    <span class="fw-bold">@Model.TotalAmount.ToString("N2") ₽</span>
                </div>
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                @if (!string.IsNullOrWhiteSpace(Model.CustomerDisplayName))
                {
                    <div class="small text-muted mb-1">Покупатель</div>
                    <div class="fw-semibold mb-3">@Model.CustomerDisplayName</div>
                }
                <form asp-action="Checkout" method="post" class="mb-3">
                    @Html.AntiForgeryToken()
                    <label asp-for="SelectedSellerUserId" class="form-label"></label>
                    <select asp-for="SelectedSellerUserId" asp-items="@Model.Sellers.ToSelectList(Model.SelectedSellerUserId)" class="form-select mb-2">
                        <option value="">Выберите продавца</option>
                    </select>
                    <span asp-validation-for="SelectedSellerUserId" class="text-danger small"></span>
                    <div class="small text-muted mb-3">
                        После оформления заказ будет создан в разделе «Продажи» у выбранного продавца.
                    </div>
                    <button type="submit" class="btn btn-primary w-100" disabled="@(!Model.CanCheckout)">
                        Оформить заказ
                    </button>
                </form>
                <form asp-action="Clear" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-danger w-100">Очистить корзину</button>
                </form>
            </div>
        </div>
    </div>
}
