@model VideoGameStoreSystem.Web.Models.Category

@{
    ViewData["Title"] = "Удаление категории";
}

<div class="page-card">
    <h2 class="fw-bold mb-3">Удаление категории</h2>
    <p>Вы действительно хотите удалить категорию <strong>@Model.CategoryName</strong>?</p>
    <p class="text-muted">Если к категории уже привязаны товары, удаление будет запрещено.</p>
    <form asp-action="Delete" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" value="@Model.CategoryId" />
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-danger">Удалить</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Отмена</a>
        </div>
    </form>
</div>
