@model VideoGameStoreSystem.Web.Models.Category

@{
    ViewData["Title"] = "Категория";
}

<div class="page-card">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="fw-bold mb-0">Категория: @Model.CategoryName</h2>
        <a asp-action="Index" class="btn btn-outline-secondary">Назад</a>
    </div>
    <dl class="row">
        <dt class="col-sm-3">ID</dt>
        <dd class="col-sm-9">@Model.CategoryId</dd>
        <dt class="col-sm-3">Название</dt>
        <dd class="col-sm-9">@Model.CategoryName</dd>
        <dt class="col-sm-3">Количество товаров</dt>
        <dd class="col-sm-9">@Model.Products.Count</dd>
    </dl>
</div>
