@model VideoGameStoreSystem.Web.ViewModels.Sales.SaleEditViewModel

@{
    var isEdit = Model.SaleId > 0;
    ViewData["Title"] = isEdit ? "Редактирование продажи" : "Новая продажа";
    while (Model.Items.Count < 5)
    {
        Model.Items.Add(new VideoGameStoreSystem.Web.ViewModels.Sales.SaleItemInputViewModel());
    }
}

<div class="page-card">
    <h2 class="fw-bold mb-3">@ViewData["Title"]</h2>
    <form asp-action="@(isEdit ? "Edit" : "Create")" method="post">
        @Html.AntiForgeryToken()
        <input asp-for="SaleId" type="hidden" />
        <div asp-validation-summary="All" class="text-danger small mb-3"></div>
        <div class="row g-3 mb-4">
            <div class="col-md-3">
                <label asp-for="SaleDate" class="form-label"></label>
                <input asp-for="SaleDate" type="date" class="form-control" />
            </div>
            <div class="col-md-4">
                <label asp-for="CustomerId" class="form-label"></label>
                <select asp-for="CustomerId" asp-items="Model.Customers.ToSelectList(Model.CustomerId)" class="form-select">
                    <option value="">Без клиента</option>
                </select>
            </div>
            <div class="col-md-5">
                <label asp-for="SellerUserId" class="form-label"></label>
                <select asp-for="SellerUserId" asp-items="Model.Sellers.ToSelectList(Model.SellerUserId)" class="form-select">
                    <option value="">Выберите продавца</option>
                </select>
                <span asp-validation-for="SellerUserId" class="text-danger small"></span>
            </div>
        </div>

        <h5 class="fw-semibold mb-3">Позиции продажи</h5>
        <div class="table-responsive">
            <table class="table table-bordered align-middle">
                <thead>
                    <tr>
                        <th>Товар</th>
                        <th>Количество</th>
                        <th>Цена продажи</th>
                    </tr>
                </thead>
                <tbody>
                    @for (var i = 0; i < Model.Items.Count; i++)
                    {
                        <tr class="document-row">
                            <td>
                                <select name="Items[@i].ProductId" class="form-select">
                                    <option value="0">Не выбрано</option>
                                    @foreach (var product in Model.Products)
                                    {
                                        <option value="@product.Value" selected="@(Model.Items[i].ProductId == product.Value)">@product.Text</option>
                                    }
                                </select>
                            </td>
                            <td><input name="Items[@i].Quantity" value="@Model.Items[i].Quantity" class="form-control" /></td>
                            <td><input name="Items[@i].UnitPrice" value="@Model.Items[i].UnitPrice" class="form-control" /></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="small text-muted mb-3">Пустые строки будут проигнорированы. Продажа не сохранится, если товара недостаточно на складе.</div>
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Сохранить</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Отмена</a>
        </div>
    </form>
</div>
