@model VideoGameStoreSystem.Web.ViewModels.Sales.SaleIndexViewModel

@{
    ViewData["Title"] = "Продажи";
}

<div class="page-card">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
        <div>
            <h2 class="fw-bold mb-1">Продажи</h2>
            <p class="text-muted mb-0">Оформление продаж и история чеков магазина видеоигр.</p>
        </div>
        <div class="d-flex gap-2">
            @if (User.HasPermission(AppPermissions.SalesManage))
            {
                <a asp-action="Create" class="btn btn-primary">Новая продажа</a>
            }
            <a asp-action="Export"
               asp-route-dateFrom="@Model.DateFrom"
               asp-route-dateTo="@Model.DateTo"
               asp-route-sellerUserId="@Model.SellerUserId"
               asp-route-minAmount="@Model.MinAmount"
               asp-route-maxAmount="@Model.MaxAmount"
               class="btn btn-outline-success">Excel</a>
        </div>
    </div>

    <form method="get" class="row g-3 mb-3">
        <div class="col-md-2">
            <label class="form-label">Дата с</label>
            <input type="date" name="dateFrom" value="@Model.DateFrom?.ToString("yyyy-MM-dd")" class="form-control" />
        </div>
        <div class="col-md-2">
            <label class="form-label">Дата по</label>
            <input type="date" name="dateTo" value="@Model.DateTo?.ToString("yyyy-MM-dd")" class="form-control" />
        </div>
        <div class="col-md-3">
            <label class="form-label">Продавец</label>
            <select name="sellerUserId" class="form-select">
                <option value="">Все продавцы</option>
                @foreach (var seller in Model.Sellers)
                {
                    <option value="@seller.Value" selected="@(Model.SellerUserId == seller.Value)">@seller.Text</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label">Сумма от</label>
            <input name="minAmount" value="@Model.MinAmount" class="form-control" />
        </div>
        <div class="col-md-2">
            <label class="form-label">Сумма до</label>
            <input name="maxAmount" value="@Model.MaxAmount" class="form-control" />
        </div>
        <div class="col-md-1 d-flex align-items-end">
            <button type="submit" class="btn btn-primary w-100">ОК</button>
        </div>
    </form>

    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Дата</th>
                    <th>Клиент</th>
                    <th>Продавец</th>
                    <th>Позиций</th>
                    <th>Сумма</th>
                    <th class="text-end">Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@item.SaleId</td>
                        <td>@item.SaleDate.ToString("dd.MM.yyyy HH:mm")</td>
                        <td>@item.Customer?.FullName</td>
                        <td>@item.SellerUser?.FullName</td>
                        <td>@item.Items.Count</td>
                        <td>@item.TotalAmount.ToString("N2") ₽</td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@item.SaleId" class="btn btn-sm btn-outline-secondary">Подробнее</a>
                            @if (User.HasPermission(AppPermissions.SalesManage))
                            {
                                <a asp-action="Edit" asp-route-id="@item.SaleId" class="btn btn-sm btn-outline-primary">Изменить</a>
                                <a asp-action="Delete" asp-route-id="@item.SaleId" class="btn btn-sm btn-outline-danger">Удалить</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
