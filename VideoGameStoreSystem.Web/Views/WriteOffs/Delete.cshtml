@model VideoGameStoreSystem.Web.Models.WriteOff

@{
    ViewData["Title"] = "Удаление списания";
}

<div class="page-card">
    <h2 class="fw-bold mb-3">Удаление списания</h2>
    <p>Удалить списание №<strong>@Model.WriteOffId</strong>?</p>
    <p class="text-muted">При удалении документа остатки товаров будут восстановлены.</p>
    <form asp-action="Delete" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" value="@Model.WriteOffId" />
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-danger">Удалить</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Отмена</a>
        </div>
    </form>
</div>
