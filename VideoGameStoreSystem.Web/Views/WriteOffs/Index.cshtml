@model VideoGameStoreSystem.Web.ViewModels.WriteOffs.WriteOffIndexViewModel

@{
    ViewData["Title"] = "Списания";
}

<div class="page-card">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
        <div>
            <h2 class="fw-bold mb-1">Списания товаров</h2>
            <p class="text-muted mb-0">Фиксация потерь и уменьшение складских остатков.</p>
        </div>
        <div class="d-flex gap-2">
            @if (User.HasPermission(AppPermissions.WriteOffsManage))
            {
                <a asp-action="Create" class="btn btn-primary">Новое списание</a>
            }
            <a asp-action="Export"
               asp-route-dateFrom="@Model.DateFrom"
               asp-route-dateTo="@Model.DateTo"
               asp-route-reason="@Model.Reason"
               class="btn btn-outline-success">Excel</a>
        </div>
    </div>

    <form method="get" class="row g-3 mb-3">
        <div class="col-md-3">
            <label class="form-label">Дата с</label>
            <input type="date" name="dateFrom" value="@Model.DateFrom?.ToString("yyyy-MM-dd")" class="form-control" />
        </div>
        <div class="col-md-3">
            <label class="form-label">Дата по</label>
            <input type="date" name="dateTo" value="@Model.DateTo?.ToString("yyyy-MM-dd")" class="form-control" />
        </div>
        <div class="col-md-4">
            <label class="form-label">Причина</label>
            <input name="reason" value="@Model.Reason" class="form-control" />
        </div>
        <div class="col-md-2 d-flex align-items-end">
            <button type="submit" class="btn btn-primary w-100">Фильтр</button>
        </div>
    </form>

    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Дата</th>
                    <th>Причина</th>
                    <th>Создал</th>
                    <th class="text-end">Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@item.WriteOffId</td>
                        <td>@item.WriteOffDate.ToString("dd.MM.yyyy")</td>
                        <td>@item.Reason</td>
                        <td>@item.CreatedByUser?.FullName</td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@item.WriteOffId" class="btn btn-sm btn-outline-secondary">Подробнее</a>
                            @if (User.HasPermission(AppPermissions.WriteOffsManage))
                            {
                                <a asp-action="Edit" asp-route-id="@item.WriteOffId" class="btn btn-sm btn-outline-primary">Изменить</a>
                                <a asp-action="Delete" asp-route-id="@item.WriteOffId" class="btn btn-sm btn-outline-danger">Удалить</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
