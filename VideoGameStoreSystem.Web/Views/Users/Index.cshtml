@model VideoGameStoreSystem.Web.ViewModels.Users.UserIndexViewModel

@{
    ViewData["Title"] = "Пользователи";
}

<div class="page-card">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
        <div>
            <h2 class="fw-bold mb-1">Пользователи системы</h2>
            <p class="text-muted mb-0">Учетные записи сотрудников и клиентов магазина.</p>
        </div>
        <div class="d-flex gap-2">
            @if (User.HasPermission(AppPermissions.UsersManage))
            {
                <a asp-action="Create" class="btn btn-primary">Добавить</a>
            }
            <a asp-action="Export"
               asp-route-search="@Model.Search"
               asp-route-roleId="@Model.RoleId"
               asp-route-isActive="@Model.IsActive"
               class="btn btn-outline-success">Excel</a>
        </div>
    </div>

    <form method="get" class="row g-3 mb-3">
        <div class="col-md-4">
            <label class="form-label">Поиск</label>
            <input name="search" value="@Model.Search" class="form-control" placeholder="Логин, ФИО или email" />
        </div>
        <div class="col-md-3">
            <label class="form-label">Роль</label>
            <select name="roleId" class="form-select">
                <option value="">Все роли</option>
                @foreach (var role in Model.Roles)
                {
                    <option value="@role.Value" selected="@(Model.RoleId == role.Value)">@role.Text</option>
                }
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label">Активность</label>
            <select name="isActive" class="form-select">
                <option value="">Все</option>
                <option value="true" selected="@(Model.IsActive == true)">Активные</option>
                <option value="false" selected="@(Model.IsActive == false)">Неактивные</option>
            </select>
        </div>
        <div class="col-md-2 d-flex align-items-end">
            <button type="submit" class="btn btn-primary w-100">Фильтр</button>
        </div>
    </form>

    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>Логин</th>
                    <th>ФИО</th>
                    <th>Email</th>
                    <th>Роль</th>
                    <th>Активен</th>
                    <th class="text-end">Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@item.Login</td>
                        <td>@item.FullName</td>
                        <td>@item.Email</td>
                        <td>@item.Role?.RoleName</td>
                        <td>@(item.IsActive ? "Да" : "Нет")</td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@item.UserId" class="btn btn-sm btn-outline-secondary">Подробнее</a>
                            @if (User.HasPermission(AppPermissions.UsersManage))
                            {
                                <a asp-action="Edit" asp-route-id="@item.UserId" class="btn btn-sm btn-outline-primary">Изменить</a>
                                <a asp-action="Delete" asp-route-id="@item.UserId" class="btn btn-sm btn-outline-danger">Удалить</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
