@model VideoGameStoreSystem.Web.Models.AppUser

@{
    ViewData["Title"] = "Удаление пользователя";
}

<div class="page-card">
    <h2 class="fw-bold mb-3">Удаление пользователя</h2>
    <p>Удалить пользователя <strong>@Model.Login</strong>?</p>
    <p class="text-muted">Если пользователь связан с документами или журналом изменений, удаление будет запрещено.</p>
    <form asp-action="Delete" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" value="@Model.UserId" />
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-danger">Удалить</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Отмена</a>
        </div>
    </form>
</div>
