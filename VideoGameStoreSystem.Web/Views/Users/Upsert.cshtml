@model VideoGameStoreSystem.Web.ViewModels.Users.UserFormViewModel

@{
    var isEdit = Model.UserId > 0;
    ViewData["Title"] = isEdit ? "Редактирование пользователя" : "Добавление пользователя";
}

<div class="page-card">
    <h2 class="fw-bold mb-3">@ViewData["Title"]</h2>
    <form asp-action="@(isEdit ? "Edit" : "Create")" method="post" class="row g-3">
        @Html.AntiForgeryToken()
        <input asp-for="UserId" type="hidden" />
        <div asp-validation-summary="ModelOnly" class="text-danger small"></div>
        <div class="col-md-4">
            <label asp-for="Login" class="form-label"></label>
            <input asp-for="Login" class="form-control" />
            <span asp-validation-for="Login" class="text-danger small"></span>
        </div>
        <div class="col-md-4">
            <label asp-for="FullName" class="form-label"></label>
            <input asp-for="FullName" class="form-control" />
            <span asp-validation-for="FullName" class="text-danger small"></span>
        </div>
        <div class="col-md-4">
            <label asp-for="Email" class="form-label"></label>
            <input asp-for="Email" class="form-control" />
            <span asp-validation-for="Email" class="text-danger small"></span>
        </div>
        <div class="col-md-4">
            <label asp-for="RoleId" class="form-label"></label>
            <select asp-for="RoleId" asp-items="Model.Roles.ToSelectList(Model.RoleId)" class="form-select">
                <option value="">Выберите роль</option>
            </select>
            <span asp-validation-for="RoleId" class="text-danger small"></span>
        </div>
        <div class="col-md-4">
            <label asp-for="Password" class="form-label"></label>
            <input asp-for="Password" class="form-control" />
            <span asp-validation-for="Password" class="text-danger small"></span>
        </div>
        <div class="col-md-4 d-flex align-items-end">
            <div class="form-check">
                <input asp-for="IsActive" class="form-check-input" />
                <label asp-for="IsActive" class="form-check-label"></label>
            </div>
        </div>
        <div class="col-12 d-flex gap-2">
            <button type="submit" class="btn btn-primary">Сохранить</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Отмена</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
