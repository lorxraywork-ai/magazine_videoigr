@model VideoGameStoreSystem.Web.ViewModels.Catalog.CatalogDetailsViewModel

@{
    ViewData["Title"] = "Карточка товара";
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
}

<div class="page-card">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
        <div>
            <span class="badge badge-soft mb-2">@Model.CategoryName</span>
            <h2 class="fw-bold">@Model.ProductName</h2>
            <div class="text-muted">@Model.Sku</div>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary">Назад в каталог</a>
    </div>
    <hr />
    <div class="row g-4">
        <div class="col-lg-8">
            <h5 class="fw-semibold">Описание</h5>
            <p class="mb-0">@Model.Description</p>
        </div>
        <div class="col-lg-4">
            <div class="entity-card p-3">
                <div class="small text-muted">Цена продажи</div>
                <div class="display-6 fw-bold">@Model.Price.ToString("N2") ₽</div>
                <div class="small text-muted mt-3">Актуальный остаток</div>
                <div class="fw-semibold">@Model.StockQuantity шт.</div>
                <div class="small text-muted mt-3">Статус</div>
                <div>@(Model.IsActive ? "Активен" : "Неактивен")</div>
                @if (Model.IsActive && Model.StockQuantity > 0)
                {
                    <form asp-controller="Cart" asp-action="Add" method="post" class="mt-3">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="productId" value="@Model.ProductId" />
                        <input type="hidden" name="returnUrl" value="@returnUrl" />
                        <label class="form-label mt-2">Количество</label>
                        <input type="number" name="quantity" value="1" min="1" max="@Model.StockQuantity" class="form-control" />
                        <button type="submit" class="btn btn-primary w-100 mt-3">
                            <i class="bi bi-cart-plus me-1"></i>Добавить в корзину
                        </button>
                    </form>
                }
                else
                {
                    <button type="button" class="btn btn-outline-secondary w-100 mt-3" disabled>Товар недоступен</button>
                }
            </div>
        </div>
    </div>
</div>
