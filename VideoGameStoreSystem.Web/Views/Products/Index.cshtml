@model VideoGameStoreSystem.Web.ViewModels.Products.ProductIndexViewModel

@{
    ViewData["Title"] = "Товары";
}

<div class="page-card">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
        <div>
            <h2 class="fw-bold mb-1">Товары</h2>
            <p class="text-muted mb-0">Ассортимент магазина видеоигр с ценами и остатками.</p>
        </div>
        <div class="d-flex gap-2">
            @if (User.HasPermission(AppPermissions.ProductsManage))
            {
                <a asp-action="Create" class="btn btn-primary">Добавить</a>
            }
            <a asp-action="Export"
               asp-route-search="@Model.Search"
               asp-route-categoryId="@Model.CategoryId"
               asp-route-minPrice="@Model.MinPrice"
               asp-route-maxPrice="@Model.MaxPrice"
               asp-route-isActive="@Model.IsActive"
               class="btn btn-outline-success">Excel</a>
        </div>
    </div>

    <form method="get" class="row g-3 mb-3">
        <div class="col-md-3">
            <label class="form-label">Название / SKU</label>
            <input name="search" value="@Model.Search" class="form-control" />
        </div>
        <div class="col-md-3">
            <label class="form-label">Категория</label>
            <select name="categoryId" class="form-select">
                <option value="">Все категории</option>
                @foreach (var category in Model.Categories)
                {
                    <option value="@category.Value" selected="@(Model.CategoryId == category.Value)">@category.Text</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label">Цена от</label>
            <input name="minPrice" value="@Model.MinPrice" class="form-control" />
        </div>
        <div class="col-md-2">
            <label class="form-label">Цена до</label>
            <input name="maxPrice" value="@Model.MaxPrice" class="form-control" />
        </div>
        <div class="col-md-2">
            <label class="form-label">Активность</label>
            <select name="isActive" class="form-select">
                <option value="">Все</option>
                <option value="true" selected="@(Model.IsActive == true)">Активные</option>
                <option value="false" selected="@(Model.IsActive == false)">Неактивные</option>
            </select>
        </div>
        <div class="col-md-2 d-flex align-items-end">
            <button type="submit" class="btn btn-primary w-100">Фильтр</button>
        </div>
    </form>

    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Товар</th>
                    <th>Категория</th>
                    <th>Цена</th>
                    <th>Остаток</th>
                    <th>Статус</th>
                    <th class="text-end">Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@item.ProductId</td>
                        <td>
                            <div class="fw-semibold">@item.ProductName</div>
                            <div class="small text-muted">@item.Sku</div>
                        </td>
                        <td>@item.Category?.CategoryName</td>
                        <td>@item.Price.ToString("N2") ₽</td>
                        <td>@item.StockQuantity</td>
                        <td>@(item.IsActive ? "Активен" : "Неактивен")</td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@item.ProductId" class="btn btn-sm btn-outline-secondary">Подробнее</a>
                            @if (User.HasPermission(AppPermissions.ProductsManage))
                            {
                                <a asp-action="Edit" asp-route-id="@item.ProductId" class="btn btn-sm btn-outline-primary">Изменить</a>
                                <a asp-action="Delete" asp-route-id="@item.ProductId" class="btn btn-sm btn-outline-danger">Удалить</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
