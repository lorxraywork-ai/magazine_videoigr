@model VideoGameStoreSystem.Web.Models.Supplier

@{
    ViewData["Title"] = "Поставщик";
}

<div class="page-card">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="fw-bold mb-0">@Model.SupplierName</h2>
        <a asp-action="Index" class="btn btn-outline-secondary">Назад</a>
    </div>
    <dl class="row">
        <dt class="col-sm-3">ID</dt>
        <dd class="col-sm-9">@Model.SupplierId</dd>
        <dt class="col-sm-3">Телефон</dt>
        <dd class="col-sm-9">@Model.Phone</dd>
        <dt class="col-sm-3">Email</dt>
        <dd class="col-sm-9">@Model.Email</dd>
        <dt class="col-sm-3">Количество поставок</dt>
        <dd class="col-sm-9">@Model.Supplies.Count</dd>
    </dl>
</div>
