@model VideoGameStoreSystem.Web.ViewModels.Suppliers.SupplierIndexViewModel

@{
    ViewData["Title"] = "Поставщики";
}

<div class="page-card">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
        <div>
            <h2 class="fw-bold mb-1">Поставщики</h2>
            <p class="text-muted mb-0">Контактная база поставщиков и партнеров магазина.</p>
        </div>
        <div class="d-flex gap-2">
            @if (User.HasPermission(AppPermissions.SuppliersManage))
            {
                <a asp-action="Create" class="btn btn-primary">Добавить</a>
            }
            <a asp-action="Export" asp-route-search="@Model.Search" class="btn btn-outline-success">Excel</a>
        </div>
    </div>

    <form method="get" class="row g-3 mb-3">
        <div class="col-md-6">
            <label class="form-label">Поиск</label>
            <input name="search" value="@Model.Search" class="form-control" placeholder="Название, email или телефон" />
        </div>
        <div class="col-md-2 d-flex align-items-end">
            <button type="submit" class="btn btn-primary w-100">Найти</button>
        </div>
    </form>

    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Поставщик</th>
                    <th>Телефон</th>
                    <th>Email</th>
                    <th class="text-end">Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@item.SupplierId</td>
                        <td>@item.SupplierName</td>
                        <td>@item.Phone</td>
                        <td>@item.Email</td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@item.SupplierId" class="btn btn-sm btn-outline-secondary">Подробнее</a>
                            @if (User.HasPermission(AppPermissions.SuppliersManage))
                            {
                                <a asp-action="Edit" asp-route-id="@item.SupplierId" class="btn btn-sm btn-outline-primary">Изменить</a>
                                <a asp-action="Delete" asp-route-id="@item.SupplierId" class="btn btn-sm btn-outline-danger">Удалить</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
