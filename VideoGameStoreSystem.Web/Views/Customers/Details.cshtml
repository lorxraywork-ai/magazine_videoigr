@model VideoGameStoreSystem.Web.Models.Customer

@{
    ViewData["Title"] = "Клиент";
}

<div class="page-card">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="fw-bold mb-0">@Model.FullName</h2>
        <a asp-action="Index" class="btn btn-outline-secondary">Назад</a>
    </div>
    <dl class="row">
        <dt class="col-sm-3">Телефон</dt>
        <dd class="col-sm-9">@Model.Phone</dd>
        <dt class="col-sm-3">Email</dt>
        <dd class="col-sm-9">@Model.Email</dd>
        <dt class="col-sm-3">Логин пользователя</dt>
        <dd class="col-sm-9">@Model.User?.Login</dd>
        <dt class="col-sm-3">Количество продаж</dt>
        <dd class="col-sm-9">@Model.Sales.Count</dd>
    </dl>
</div>
