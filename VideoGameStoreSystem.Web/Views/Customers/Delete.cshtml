@model VideoGameStoreSystem.Web.Models.Customer

@{
    ViewData["Title"] = "Удаление клиента";
}

<div class="page-card">
    <h2 class="fw-bold mb-3">Удаление клиента</h2>
    <p>Удалить клиента <strong>@Model.FullName</strong>?</p>
    <p class="text-muted">Если у клиента уже есть продажи, удаление будет запрещено.</p>
    <form asp-action="Delete" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" value="@Model.CustomerId" />
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-danger">Удалить</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Отмена</a>
        </div>
    </form>
</div>
