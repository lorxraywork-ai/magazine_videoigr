@model VideoGameStoreSystem.Web.ViewModels.Supplies.SupplyEditViewModel

@{
    var isEdit = Model.SupplyId > 0;
    ViewData["Title"] = isEdit ? "Редактирование поступления" : "Новое поступление";
    while (Model.Items.Count < 5)
    {
        Model.Items.Add(new VideoGameStoreSystem.Web.ViewModels.Supplies.SupplyItemInputViewModel());
    }
}

<div class="page-card">
    <h2 class="fw-bold mb-3">@ViewData["Title"]</h2>
    <form asp-action="@(isEdit ? "Edit" : "Create")" method="post">
        @Html.AntiForgeryToken()
        <input asp-for="SupplyId" type="hidden" />
        <div asp-validation-summary="All" class="text-danger small mb-3"></div>

        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <label asp-for="SupplyDate" class="form-label"></label>
                <input asp-for="SupplyDate" type="date" class="form-control" />
            </div>
            <div class="col-md-8">
                <label asp-for="SupplierId" class="form-label"></label>
                <select asp-for="SupplierId" asp-items="Model.Suppliers.ToSelectList(Model.SupplierId)" class="form-select">
                    <option value="">Выберите поставщика</option>
                </select>
                <span asp-validation-for="SupplierId" class="text-danger small"></span>
            </div>
        </div>

        <h5 class="fw-semibold mb-3">Позиции документа</h5>
        <div class="table-responsive">
            <table class="table table-bordered align-middle">
                <thead>
                    <tr>
                        <th>Товар</th>
                        <th>Количество</th>
                        <th>Цена закупки</th>
                    </tr>
                </thead>
                <tbody>
                    @for (var i = 0; i < Model.Items.Count; i++)
                    {
                        <tr class="document-row">
                            <td>
                                <select name="Items[@i].ProductId" class="form-select">
                                    <option value="0">Не выбрано</option>
                                    @foreach (var product in Model.Products)
                                    {
                                        <option value="@product.Value" selected="@(Model.Items[i].ProductId == product.Value)">@product.Text</option>
                                    }
                                </select>
                            </td>
                            <td><input name="Items[@i].Quantity" value="@Model.Items[i].Quantity" class="form-control" /></td>
                            <td><input name="Items[@i].UnitCost" value="@Model.Items[i].UnitCost" class="form-control" /></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="small text-muted mb-3">Заполните нужные строки. Пустые строки будут проигнорированы при сохранении.</div>
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Сохранить</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Отмена</a>
        </div>
    </form>
</div>
