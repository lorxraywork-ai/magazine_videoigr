@model VideoGameStoreSystem.Web.ViewModels.Supplies.SupplyIndexViewModel

@{
    ViewData["Title"] = "Поступления";
}

<div class="page-card">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
        <div>
            <h2 class="fw-bold mb-1">Поступления товаров</h2>
            <p class="text-muted mb-0">Документы приемки товара от поставщиков.</p>
        </div>
        <div class="d-flex gap-2">
            @if (User.HasPermission(AppPermissions.SuppliesManage))
            {
                <a asp-action="Create" class="btn btn-primary">Новое поступление</a>
            }
            <a asp-action="Export"
               asp-route-supplierId="@Model.SupplierId"
               asp-route-dateFrom="@Model.DateFrom"
               asp-route-dateTo="@Model.DateTo"
               asp-route-minAmount="@Model.MinAmount"
               asp-route-maxAmount="@Model.MaxAmount"
               class="btn btn-outline-success">Excel</a>
        </div>
    </div>

    <form method="get" class="row g-3 mb-3">
        <div class="col-md-3">
            <label class="form-label">Поставщик</label>
            <select name="supplierId" class="form-select">
                <option value="">Все поставщики</option>
                @foreach (var supplier in Model.Suppliers)
                {
                    <option value="@supplier.Value" selected="@(Model.SupplierId == supplier.Value)">@supplier.Text</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label">Дата с</label>
            <input type="date" name="dateFrom" value="@Model.DateFrom?.ToString("yyyy-MM-dd")" class="form-control" />
        </div>
        <div class="col-md-2">
            <label class="form-label">Дата по</label>
            <input type="date" name="dateTo" value="@Model.DateTo?.ToString("yyyy-MM-dd")" class="form-control" />
        </div>
        <div class="col-md-2">
            <label class="form-label">Сумма от</label>
            <input name="minAmount" value="@Model.MinAmount" class="form-control" />
        </div>
        <div class="col-md-2">
            <label class="form-label">Сумма до</label>
            <input name="maxAmount" value="@Model.MaxAmount" class="form-control" />
        </div>
        <div class="col-md-1 d-flex align-items-end">
            <button type="submit" class="btn btn-primary w-100">ОК</button>
        </div>
    </form>

    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Дата</th>
                    <th>Поставщик</th>
                    <th>Позиций</th>
                    <th>Сумма</th>
                    <th class="text-end">Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@item.SupplyId</td>
                        <td>@item.SupplyDate.ToString("dd.MM.yyyy")</td>
                        <td>@item.Supplier?.SupplierName</td>
                        <td>@item.Items.Count</td>
                        <td>@item.TotalAmount.ToString("N2") ₽</td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@item.SupplyId" class="btn btn-sm btn-outline-secondary">Подробнее</a>
                            @if (User.HasPermission(AppPermissions.SuppliesManage))
                            {
                                <a asp-action="Edit" asp-route-id="@item.SupplyId" class="btn btn-sm btn-outline-primary">Изменить</a>
                                <a asp-action="Delete" asp-route-id="@item.SupplyId" class="btn btn-sm btn-outline-danger">Удалить</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
