@{
    var toastMessage = TempData["ToastMessage"]?.ToString();
    var toastTitle = TempData["ToastTitle"]?.ToString() ?? "Сообщение";
    var toastType = TempData["ToastType"]?.ToString() ?? "info";
}

@if (!string.IsNullOrWhiteSpace(toastMessage))
{
    <div class="toast-container position-fixed top-0 end-0 p-3">
        <div class="toast align-items-center text-bg-@toastType border-0 app-toast" role="alert" aria-live="assertive" aria-atomic="true" data-app-toast="true">
            <div class="d-flex">
                <div class="toast-body">
                    <strong class="d-block mb-1">@toastTitle</strong>
                    @toastMessage
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div>
        </div>
    </div>
}
