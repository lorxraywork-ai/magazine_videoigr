@model ErrorViewModel

@{
    ViewData["Title"] = "Ошибка";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="page-card text-center">
            <div class="display-4 text-danger mb-3"><i class="bi bi-exclamation-octagon"></i></div>
            <h1 class="fw-bold mb-3">Произошла ошибка</h1>
            <p class="text-muted mb-4">Во время обработки запроса возникло исключение. Попробуйте повторить действие позже или обратитесь к администратору системы.</p>

            @if (Model.ShowRequestId)
            {
                <p><strong>Идентификатор запроса:</strong> <code>@Model.RequestId</code></p>
            }

            <a asp-controller="Home" asp-action="Index" class="btn btn-primary">Вернуться на главную</a>
        </div>
    </div>
</div>
