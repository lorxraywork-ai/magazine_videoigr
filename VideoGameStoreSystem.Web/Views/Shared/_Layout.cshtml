<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Магазин видеоигр</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/VideoGameStoreSystem.Web.styles.css" asp-append-version="true" />
</head>
<body class="app-body">
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark app-navbar shadow-sm">
            <div class="container">
                <a class="navbar-brand fw-semibold" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-controller me-2"></i>ИС магазина видеоигр
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Главная</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Catalog" asp-action="Index">Каталог</a></li>
                        @if (User.HasPermission(AppPermissions.ProductsView))
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Products" asp-action="Index">Товары</a></li>
                        }
                        @if (User.HasPermission(AppPermissions.CategoriesView))
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Categories" asp-action="Index">Категории</a></li>
                        }
                        @if (User.HasPermission(AppPermissions.SuppliersView))
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Suppliers" asp-action="Index">Поставщики</a></li>
                        }
                        @if (User.HasPermission(AppPermissions.SuppliesView))
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Supplies" asp-action="Index">Поступления</a></li>
                        }
                        @if (User.HasPermission(AppPermissions.WriteOffsView))
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="WriteOffs" asp-action="Index">Списания</a></li>
                        }
                        @if (User.HasPermission(AppPermissions.SalesView))
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Sales" asp-action="Index">Продажи</a></li>
                        }
                        @if (User.HasPermission(AppPermissions.CustomersView))
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Customers" asp-action="Index">Клиенты</a></li>
                        }
                        @if (User.HasPermission(AppPermissions.ReportsView))
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Reports" asp-action="Index">Отчеты</a></li>
                        }
                    </ul>
                    <div class="d-flex align-items-center gap-2 flex-wrap">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <a asp-controller="Profile" asp-action="Index" class="btn btn-outline-light btn-sm">
                                <i class="bi bi-person-circle me-1"></i>@User.Identity.Name
                            </a>
                            <span class="text-white-50 small">@User.FindFirstValue(ClaimTypes.GivenName) · @User.FindFirstValue(ClaimTypes.Role)</span>
                            <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-light btn-sm">Выход</button>
                            </form>
                        }
                        else
                        {
                            <a asp-controller="Account" asp-action="Login" class="btn btn-outline-light btn-sm">Вход</a>
                            <a asp-controller="Account" asp-action="Register" class="btn btn-light btn-sm">Регистрация</a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>
    <main class="container py-4">
        @await Html.PartialAsync("Partials/_Toast")
        @RenderBody()
    </main>
    <footer class="app-footer">
        <div class="container py-3 small text-muted">
            Информационная система магазина видеоигр на ASP.NET Core MVC, EF Core и SQL Server.
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
