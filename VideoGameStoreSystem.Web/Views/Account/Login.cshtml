@model VideoGameStoreSystem.Web.ViewModels.Account.LoginViewModel

@{
    ViewData["Title"] = "Вход";
}

<div class="row justify-content-center">
    <div class="col-lg-5">
        <div class="page-card">
            <h2 class="fw-bold mb-3">Вход в систему</h2>
            <p class="text-muted">Авторизуйтесь для доступа к рабочим разделам магазина видеоигр.</p>

            <form asp-action="Login" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                <div class="mb-3">
                    <label asp-for="Login" class="form-label"></label>
                    <input asp-for="Login" class="form-control" />
                    <span asp-validation-for="Login" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Password" class="form-label"></label>
                    <input asp-for="Password" class="form-control" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>
                <div class="form-check mb-3">
                    <input asp-for="RememberMe" class="form-check-input" />
                    <label asp-for="RememberMe" class="form-check-label"></label>
                </div>
                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-primary">Войти</button>
                    <a asp-action="Register" class="btn btn-outline-primary">Регистрация клиента</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
